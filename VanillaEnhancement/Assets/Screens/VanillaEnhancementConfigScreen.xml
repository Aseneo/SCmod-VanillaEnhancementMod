<Screen xmlns="runtime-namespace:Game">

  <PanoramaWidget />

  <StackPanelWidget Direction="Horizontal">

    <CanvasWidget Style="{Widgets/TopBarContents}">
      <LabelWidget Name="TopBar.Label" Text="[VanillaEnhancementConfig:0]" />
    </CanvasWidget>

    <CanvasWidget Margin="10, 20">
      <BevelledRectangleWidget Style="{Styles/Area}" />
      <ScrollPanelWidget Direction="Vertical" HorizontalAlignment="Center" Margin="3, 3">
        <StackPanelWidget Name="ContentStack" Direction="Vertical" HorizontalAlignment="Center" />
      </ScrollPanelWidget>
    </CanvasWidget>

  </StackPanelWidget>
</Screen>
